{
  "manifest_version": 3,
  "name": "JobPilot - AI Job Search Copilot",
  "version": "0.1.0",
  "description": "一键提取招聘页面 JD，发送到 JobPilot 进行 AI 解析和匹配",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:8001/*", "http://localhost:8001/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobPilot"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
