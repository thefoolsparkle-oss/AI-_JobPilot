# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Database (override for production PostgreSQL)
DATABASE_URL=postgresql://jobpilot:jobpilot@db:5432/jobpilot

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=60

# LLM settings
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=2
